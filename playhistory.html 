<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Play History - Shinzi Music</title>
    <style>
        body { 
            background-color: #000; 
            color: #fff; 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            padding: 24px; 
            margin: 0;
        }
        h1 { font-size: 28px; font-weight: 800; margin-bottom: 24px; letter-spacing: -0.5px; }
        .back-btn { 
            color: #1db954; 
            text-decoration: none; 
            font-weight: 700; 
            margin-bottom: 24px; 
            display: inline-block; 
            font-size: 16px;
        }
        .history-item { 
            display: flex; 
            align-items: center; 
            gap: 16px; 
            background: rgba(255,255,255,0.05); 
            padding: 12px; 
            margin-bottom: 12px; 
            border-radius: 8px; 
        }
        .album-art { width: 56px; height: 56px; border-radius: 6px; object-fit: cover; }
        .song-info { display: flex; flex-direction: column; justify-content: center; }
        .song-title { font-weight: 700; font-size: 16px; margin-bottom: 4px; }
        .song-artist { color: #a7a7a7; font-size: 13px; }
    </style>
</head>
<body>
    <a href="index.html" class="back-btn">← Back to Home</a>
    <h1>Listening History</h1>

    <div id="history-list">
        <p style="color:#a7a7a7;">Loading your history...</p>
    </div>

    <!-- 🔥 This pulls the history logic -->
    <script type="module" src="history.js"></script>
</body>
</html>