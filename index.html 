<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta charset="UTF-8">
    <title>Shinzi Music</title>

    <style>
        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --bg-card: #121212;
            --bg-card-hover: #2a2a2a;
            --text-main: #ffffff;
            --text-sub: #a7a7a7;
            --accent: #1db954; 
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-main); color: var(--text-main); overflow: hidden; height: 100vh; display: flex; flex-direction: column; }
        .hidden { display: none !important; }

        /* 🔥 NEW: Hides the player completely if nothing is active */
        .hidden-player { display: none !important; }

        .app-container { display: flex; flex: 1; height: calc(100vh - 90px); }

        /* Sidebar Desktop */
        .sidebar { width: 240px; background-color: var(--bg-sidebar); padding: 24px; display: flex; flex-direction: column; gap: 24px; }
        .logo-container { display: flex; align-items: center; gap: 12px; font-size: 22px; font-weight: 800; color: var(--text-main); letter-spacing: -0.5px; }
        .brand-logo-img { width: 40px; height: 40px; object-fit: cover; object-position: center 15%; border-radius: 50%; box-shadow: 0 4px 12px rgba(138, 43, 226, 0.4); }

        .nav-links { display: flex; flex-direction: column; gap: 16px; list-style: none; flex: 1; }
        .nav-item { color: var(--text-sub); text-decoration: none; font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 16px; cursor: pointer; transition: color 0.2s ease; }
        .nav-item:hover, .nav-item.active { color: var(--text-main); }
        .nav-item svg { width: 24px; height: 24px; }

        /* Main Viewport */
        .main-content { flex: 1; background: linear-gradient(to bottom, #1f1f1f 0%, var(--bg-main) 300px); overflow-y: auto; padding: 32px; padding-bottom: 120px; }

        /* Top Bar & Profile Icon */
        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .top-bar h1 { margin-bottom: 0; font-size: 32px; font-weight: 800; letter-spacing: -1px; }
        .profile-icon { width: 42px; height: 42px; border-radius: 50%; background-color: var(--accent); color: #000; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 800; cursor: pointer; text-transform: uppercase; box-shadow: 0 4px 12px rgba(29, 185, 84, 0.4); transition: transform 0.2s; text-decoration: none; }
        .profile-icon:hover { transform: scale(1.1); }

        h2 { font-size: 24px; font-weight: 700; margin: 40px 0 20px 0; letter-spacing: -0.5px; }

        /* Quick Shortcuts & Cards */
        .quick-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px; }
        .quick-card { background: rgba(255,255,255,0.08); border-radius: 6px; display: flex; align-items: center; overflow: hidden; cursor: pointer; transition: background-color 0.3s ease, transform 0.2s ease; }
        .quick-card:hover { background: rgba(255,255,255,0.15); transform: scale(1.02); }
        .quick-card-img { width: 80px; height: 80px; background: #282828; display: flex; align-items: center; justify-content: center; box-shadow: 4px 0 10px rgba(0,0,0,0.3); }
        .quick-card h3 { font-size: 16px; padding: 16px; font-weight: 700; }

        .shelf-row { display: flex; gap: 24px; overflow-x: auto; padding-bottom: 12px; scroll-behavior: smooth; }
        .shelf-row::-webkit-scrollbar { display: none; }
        .music-card { background-color: var(--bg-card); min-width: 180px; max-width: 180px; padding: 16px; border-radius: 8px; cursor: pointer; position: relative; transition: background-color 0.3s ease; }
        .music-card:hover { background-color: var(--bg-card-hover); }
        .card-thumb { width: 148px; height: 148px; object-fit: cover; border-radius: 6px; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
        .card-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .card-sub { font-size: 13px; color: var(--text-sub); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .card-play { position: absolute; right: 24px; top: 116px; width: 48px; height: 48px; border-radius: 50%; background-color: var(--accent); border: none; display: flex; align-items: center; justify-content: center; opacity: 0; transform: translateY(8px); transition: all 0.3s ease; box-shadow: 0 8px 16px rgba(0,0,0,0.4); cursor: pointer; }
        .music-card:hover .card-play { opacity: 1; transform: translateY(0); }

        /* Search Interface */
        .search-container { position: relative; max-width: 500px; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }
        .search-input-field { width: 100%; padding: 14px 48px; border-radius: 50px; border: 2px solid transparent; background-color: #242424; color: #ffffff; font-size: 14px; font-weight: 500; outline: none; transition: border-color 0.3s ease; }
        .search-input-field:focus { border-color: #ffffff; background-color: #2a2a2a; }
        .search-icon-left { position: absolute; left: 16px; top: 12px; width: 20px; height: 20px; color: #a7a7a7; }
        .search-clear-btn { background: none; border: none; color: var(--text-sub); cursor: pointer; padding: 10px; }
        .results-vertical-list { display: flex; flex-direction: column; gap: 8px; margin-top: 16px; }
        .search-item { display: flex; align-items: center; gap: 16px; padding: 12px; border-radius: 6px; cursor: pointer; transition: background-color 0.2s ease; }
        .search-item:hover { background-color: rgba(255,255,255,0.1); }
        .search-thumb { width: 56px; height: 56px; object-fit: cover; border-radius: 4px; }
        .search-info { flex: 1; min-width: 0; }
        .search-title { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #fff; }
        .search-channel { font-size: 13px; color: var(--text-sub); margin-top: 4px; }

        /* Settings Integrated UI */
        .menu-list { display: flex; flex-direction: column; gap: 12px; }
        .menu-item { background: var(--bg-card); padding: 16px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; color: var(--text-main); text-decoration: none; font-weight: 600; font-size: 15px; transition: background 0.2s; }
        .menu-item:hover { background: #1a1a1a; }
        .menu-item-left { display: flex; align-items: center; gap: 16px; }
        .logout-btn { background: #2a0e0e; color: #ff4444; text-align: center; justify-content: center; margin-top: 24px; padding: 16px; border-radius: 8px; font-weight: 700; cursor: pointer; display: block; border: none; width: 100%; font-size: 16px; }

        /* Persistent Bottom Player Console */
        .playback-console-bar { height: 90px; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(15px); border-top: 1px solid #282828; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; position: fixed; bottom: 0; left: 0; right: 0; z-index: 999; cursor: pointer; }

        /* 🔥 FIXED: Flexbox shrink logic to ensure mobile buttons NEVER get hidden */
        .track-metadata-block { display: flex; align-items: center; justify-content: space-between; gap: 14px; width: 30%; min-width: 180px; }
        .meta-text-details { min-width: 0; flex: 1; overflow: hidden; }
        .meta-right-actions { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }

        .meta-artwork-frame { width: 56px; height: 56px; background-color: #282828; border-radius: 6px; overflow: hidden; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.5); flex-shrink: 0; }
        .meta-track-name { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .meta-artist-name { font-size: 12px; color: var(--text-sub); margin-top: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .np-heart-btn { background: none; border: none; color: var(--text-sub); cursor: pointer; transition: color 0.2s; padding: 4px; display: flex; align-items: center; }
        .np-heart-btn.liked { color: var(--accent); }

        .core-controls-wrapper { display: flex; flex-direction: column; align-items: center; gap: 8px; width: 40%; max-width: 700px; }
        .button-cluster { display: flex; align-items: center; gap: 24px; }
        .media-action-btn { background: none; border: none; color: var(--text-sub); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.2s ease; }
        .media-action-btn:hover { color: var(--text-main); }
        .media-action-btn.active-mode { color: var(--accent); }
        .btn-master-play { width: 32px; height: 32px; border-radius: 50%; background-color: #ffffff; color: #000000 !important; transform: scale(1); transition: transform 0.1s; }
        .btn-master-play:hover { transform: scale(1.1); }

        .timeline-slider-row { display: flex; align-items: center; gap: 8px; width: 100%; }
        .timestamp-label { font-size: 11px; color: var(--text-sub); min-width: 40px; text-align: center; }
        .progress-track-bar { flex: 1; height: 4px; background-color: #4f4f4f; border-radius: 2px; position: relative; cursor: pointer; overflow: hidden; }
        .progress-fill-line { height: 100%; background-color: #ffffff; border-radius: 2px; width: 0%; transition: background-color 0.2s; }

        /* INNER FULLSCREEN PLAYER */
        .inner-player-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: linear-gradient(180deg, #2a2a2a 0%, #000000 100%); z-index: 2000; display: flex; flex-direction: column; padding: 24px; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); overflow-y: auto; }
        .inner-player-screen.active { transform: translateY(0); }
        .inner-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; padding-top: 10px; }
        .close-inner-btn { background: none; border: none; color: #fff; cursor: pointer; }
        .inner-header-text { font-size: 12px; font-weight: 700; letter-spacing: 1px; color: var(--text-main); text-transform: uppercase; }

        .inner-artwork-container { width: 100%; aspect-ratio: 1/1; max-width: 350px; margin: 0 auto 40px auto; border-radius: 8px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
        .inner-artwork-container img { width: 100%; height: 100%; object-fit: cover; }

        .inner-track-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .inner-text-details { min-width: 0; flex: 1; padding-right: 16px; }
        .inner-title { font-size: 24px; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
        .inner-artist { font-size: 16px; color: var(--text-sub); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .inner-timeline { margin-bottom: 30px; }
        .inner-time-labels { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-sub); margin-top: 8px; }
        .inner-progress-bar { width: 100%; height: 4px; background-color: #4f4f4f; border-radius: 2px; position: relative; cursor: pointer; }
        .inner-progress-fill { height: 100%; background-color: #fff; border-radius: 2px; width: 0%; }

        .inner-controls { display: flex; justify-content: space-between; align-items: center; max-width: 350px; margin: 0 auto; width: 100%; }
        .inner-play-btn { width: 64px; height: 64px; border-radius: 50%; background-color: #fff; color: #000; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; }

        /* Responsive Mobile */
        @media (max-width: 768px) {
            .sidebar { display: none; }
            .main-content { padding: 64px 16px 16px 16px; padding-bottom: 160px; background: linear-gradient(to bottom, #1f1f1f 0%, var(--bg-main) 150px); }
            .top-bar { margin-top: 0px; margin-bottom: 32px; }
            .top-bar h1 { font-size: 22px; }
            .quick-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .music-card { min-width: 140px; max-width: 140px; padding: 12px; }
            .card-thumb { width: 116px; height: 116px; margin-bottom: 8px; }

            .playback-console-bar { bottom: 70px; height: 60px; padding: 0 12px; border-radius: 8px; margin: 8px; width: calc(100% - 16px); background-color: rgba(30, 30, 30, 0.95); box-shadow: 0 4px 20px rgba(0,0,0,0.8); }
            .secondary-utilities-block, .core-controls-wrapper { display: none; }
            .track-metadata-block { width: 100%; }

            .mobile-bottom-navbar { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px); border-top: 1px solid #282828; display: flex; justify-content: space-around; z-index: 1000; padding: 8px 0; }
            .mobile-nav-btn { background: none; border: none; color: var(--text-sub); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; font-size: 12px; font-weight: 500; cursor: pointer; transition: color 0.2s; padding: 8px; }
            .mobile-nav-btn.active, .mobile-nav-btn:hover { color: var(--text-main); }
        }
        @media (min-width: 769px) { .mobile-bottom-navbar { display: none; } .mobile-mini-play { display: none; } }
    </style>
</head>
