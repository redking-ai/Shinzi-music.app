<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to Shinzi Music</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
        body { background-color: #000; color: #fff; display: flex; align-items: center; justify-content: center; height: 100vh; overflow: hidden; }
        .auth-card { background: rgba(18, 18, 18, 0.9); backdrop-filter: blur(20px); padding: 40px; border-radius: 12px; width: 100%; max-width: 400px; text-align: center; border: 1px solid #282828; box-shadow: 0 10px 30px rgba(0,0,0,0.8); }
        .logo { width: 80px; border-radius: 50%; margin-bottom: 20px; box-shadow: 0 4px 12px rgba(138, 43, 226, 0.4); }
        h1 { font-size: 24px; margin-bottom: 8px; font-weight: 800; }
        p { color: #a7a7a7; font-size: 14px; margin-bottom: 30px; }
        .btn { display: block; width: 100%; padding: 14px; border-radius: 50px; border: none; font-size: 16px; font-weight: 700; cursor: pointer; transition: transform 0.2s; margin-bottom: 16px; text-decoration: none; text-align: center; }
        .btn:hover { transform: scale(1.02); }
        .btn-primary { background-color: #1db954; color: #000; }
        .btn-secondary { background-color: transparent; color: #fff; border: 1px solid #a7a7a7; }
    </style>
</head>
<body>
    <div class="auth-card">
        <img src="shinzimusic.png" alt="Shinzi Music Logo" class="logo">
        <h1>Ready To Listen?</h1>
        <p>Theres 100 Million+ Musics!</p>

        <a href="signup.html" class="btn btn-primary">Sign UP</a>
        <a href="login.html" class="btn btn-secondary">Log in</a>
    </div>
</body>
</html>